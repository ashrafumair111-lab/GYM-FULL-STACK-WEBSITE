# ===========================================
# Gym Store API — Environment Configuration
# Copy to ".env" and adjust values.
# ===========================================
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gym_store
DB_CONNECTION_LIMIT=10

# CORS
CORS_ORIGIN=*
